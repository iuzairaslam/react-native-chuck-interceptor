{
  "compilerOptions": {
    "target": "ES2017",
    "module": "ESNext",
    "moduleResolution": "node",
    "jsx": "react-native",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "declaration": true,
    "declarationDir": "lib",
    "outDir": "lib",
    "lib": ["ES2017", "DOM"]
  },
  "include": ["src", "src/global.d.ts"],
  "exclude": ["node_modules", "lib", "example"]
}
