{
  "name": "@iuzairaslam/react-native-chuck-interceptor",
  "version": "1.0.11",
  "description": "Network inspector for React Native (fetch, XHR, Axios). View requests, responses, headers, JSON and FormData in an in-app dashboard — inspired by Chucker.",
  "main": "src/index.ts",
  "module": "src/index.ts",
  "react-native": "src/index.ts",
  "source": "src/index.ts",
  "types": "src/index.ts",
  "files": [
    "src",
    "babel.config.js",
    "tsconfig.json",
    "README.md"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "publish:npm": "npm publish --registry=https://registry.npmjs.org --access public",
    "publish:github": "npm publish --registry=https://npm.pkg.github.com"
  },
  "keywords": [
    "react-native",
    "react native",
    "network",
    "inspector",
    "network inspector",
    "http inspector",
    "api inspector",
    "http",
    "https",
    "chucker",
    "chuck",
    "chucker-like",
    "network-inspector",
    "api-debugger",
    "http-debugger",
    "network-debugger",
    "request-inspector",
    "response-inspector",
    "axios",
    "axios-interceptor",
    "fetch",
    "fetch-interceptor",
    "xmlhttprequest",
    "xhr",
    "xhr-interceptor",
    "devtools",
    "debugger",
    "interceptor",
    "in-app devtools",
    "ios",
    "android"
  ],
  "author": {
    "name": "Muhammad Uzair Aslam",
    "url": "https://github.com/iuzairaslam/"
  },
  "license": "MIT",
  "peerDependencies": {
    "react": ">=17.0.0",
    "react-native": ">=0.71.0"
  },
  "peerDependenciesMeta": {
    "@react-native-async-storage/async-storage": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^18.0.0",
    "@types/react-native": "^0.73.0",
    "typescript": "^5.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iuzairaslam/react-native-chuck-interceptor.git"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "homepage": "https://github.com/iuzairaslam/react-native-chuck-interceptor#readme",
  "bugs": {
    "url": "https://github.com/iuzairaslam/react-native-chuck-interceptor/issues"
  }
}
